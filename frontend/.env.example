# Frontend Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration (DO NOT include /api suffix - frontend code adds it)
# Local Development: http://localhost:5001
# Dev Environment: https://optio-dev-backend.onrender.com
# Production: https://optio-prod-backend.onrender.com
VITE_API_URL=http://localhost:5001

# Supabase Configuration
VITE_SUPABASE_URL=https://vvfgxcykxjybtvpfzwyx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe Configuration (Public Keys - safe to expose)
VITE_STRIPE_PUBLIC_KEY=pk_test_your-stripe-publishable-key

# PostHog Analytics (optional -- omit to disable tracking in local dev)
# VITE_POSTHOG_KEY=phc_your-posthog-key
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Application Settings
VITE_APP_NAME=Optio Education Platform
VITE_APP_VERSION=3.0.0

# Environment Indicator (development/staging/production)
VITE_ENVIRONMENT=development