# Backend Environment Configuration
# Copy this file to .env and fill in your values
# All keys are accessed via the Config class in app_config.py

# =============================================================================
# Required: Flask
# =============================================================================
FLASK_ENV=development
FLASK_SECRET_KEY=your-64-character-secret-key-here-change-in-production

# =============================================================================
# Required: Supabase
# =============================================================================
SUPABASE_URL=https://vvfgxcykxjybtvpfzwyx.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# Required: CORS / Frontend
# =============================================================================
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=https://optio-dev-frontend.onrender.com,https://www.optioeducation.com

# =============================================================================
# AI: Google Gemini
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash-lite  # Default, override if needed

# =============================================================================
# Images: Pexels
# =============================================================================
PEXELS_API_KEY=your-pexels-api-key

# =============================================================================
# Email: SendGrid SMTP
# =============================================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SENDER_EMAIL=support@optioeducation.com
SENDER_NAME=Optio Support
ADMIN_EMAIL=tanner@optioeducation.com
SUPPORT_EMAIL=support@optioeducation.com
SUPPORT_COPY_EMAIL=tanner@optioeducation.com

# =============================================================================
# Payments: Stripe
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# Cron Authentication
# =============================================================================
CRON_SECRET=your-cron-secret-key

# =============================================================================
# Web Push Notifications (VAPID)
# Generate keys: npx web-push generate-vapid-keys
# =============================================================================
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_MAILTO=mailto:support@optioeducation.com

# =============================================================================
# Platform Admin
# =============================================================================
SUPERADMIN_EMAIL=tannerbowman@gmail.com

# =============================================================================
# Logging (optional)
# =============================================================================
# LOG_LEVEL=WARNING
# LOG_FORMAT=json
